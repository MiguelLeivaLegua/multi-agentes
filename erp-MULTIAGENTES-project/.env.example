# ============================================================
# .env.example - Variables de Entorno del ERP Veterinaria
# ============================================================
# Copiar este archivo a .env y completar los valores:
#   cp .env.example .env
#
# ⚠️ NUNCA subir .env a Git — contiene secretos.
# ============================================================

# --- DeepSeek API ---
DEEPSEEK_API_KEY=tu-api-key-aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=120

# --- Base de Datos ---
DB_HOST=localhost
DB_NAME=veterinaria_erp
DB_USER=tu-usuario
DB_PASSWORD=tu-contraseña
